# Copie este arquivo para .env e preencha os valores

# Chave secreta do Django (obrigatorio em producao)
SECRET_KEY=sua-chave-secreta-aqui

# Dominios permitidos separados por virgula
ALLOWED_HOSTS=localhost,127.0.0.1

# URI do banco de dados (padrao: SQLite local)
# Para PostgreSQL: postgresql://usuario:senha@host:5432/nome_db
DATABASE_URL=sqlite:///db.sqlite3

# Modo debug (False em producao)
DEBUG=True

# Segurança em producao
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
